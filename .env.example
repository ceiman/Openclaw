# Google Gemini API Key
# Nota: Ambas variables usan la MISMA clave de Google AI Studio
GOOGLE_API_KEY=tu_api_key_aqui
GEMINI_API_KEY=tu_api_key_aqui

# Telegram Configuration
TELEGRAM_TOKEN=tu_token_de_telegram_aqui

# Model Selection (Ya configurados para Gemini 3 Flash)
GEMINI_MODEL=gemini-3-flash-preview
OPENCLAW_AGENT_MODEL=google/gemini-3-flash-preview
OPENCLAW_MODEL=gemini-3-flash-preview
